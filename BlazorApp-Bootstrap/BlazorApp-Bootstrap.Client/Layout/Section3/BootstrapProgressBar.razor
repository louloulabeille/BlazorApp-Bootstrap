<!-- my-1 marge en haut et en bas de 1rem -->
<div class="container my-1">
    <div class="progress">
        <div class="progress-bar" role="progressbar" aria-label="Basic example" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
</div>
<div class="container my-1">
    <div class="progress">
        <div class="progress-bar" role="progressbar" aria-label="Basic example" style="width: 25%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
</div>
<div class="container my-1">
    <div class="progress"><!-- strillé et animé -->
        <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" role="progressbar" aria-label="Basic example" style="width: 50%" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
</div>
<div class="container my-1">
    <div class="progress" style="height: 50px;"><!-- taille en hauteur de 50px -->
        <!-- on peut strillé la progress bar -->
        <div class="progress-bar progress-bar-striped" role="progressbar" aria-label="Basic example" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">75%</div>
    </div>
</div>
<div class="container my-1">
    <div class="progress"><!-- rajouter du texte dans la progress bar  avec changement du background color -->
        <div class="progress-bar bg-success" role="progressbar" aria-label="Basic example" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">100%</div>
    </div>
</div>


