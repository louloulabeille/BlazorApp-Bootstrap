<!-- Rien à faire juste mettre le code et eventuellement le code pour prendre le Focus sur un object de la fenêtre modal -->

<!-- Button trigger modal -->
<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exampleModal">
    Launch demo modal
</button>

<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
                <!-- petite croix pour fermer -->
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Le biathlon est chouette woo wooo.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="btn-Modal-Close" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="btn-Modal-SaveChange" >Save changes</button>
            </div>
        </div>
    </div>
</div>



