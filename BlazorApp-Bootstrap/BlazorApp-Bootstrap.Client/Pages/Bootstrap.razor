    <div class="container">
        <div class="row">

            <!-- class="col-lg-6" on prend la class colonne dont la surface est divivée par 12 -->
            <!-- ici on prend 6 et au col-lg à partir de lg >= 992px les 2 blocks seront côte à côte -->
            <div id="block1" class="col-lg-6" style="border: 1px solid chocolate">
                <h1>Ma page</h1>
                <p>Mon premier paragraphe</p>
            </div>
            <div id="block2" class="col-lg-6" style="border: 1px solid chocolate">
                <h1>Ma page</h1>
                <p>Mon premier paragraphe</p>
            </div>
        </div>
    </div>
    
}
